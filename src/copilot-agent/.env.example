# BYOK auth only — Foundry model via Managed Identity.
# FOUNDRY_PROJECT_ENDPOINT is auto-injected when deployed as a hosted agent.
# Set both vars when running locally against a Foundry project.

FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4

# Optional — session ID for persistence/resume across restarts.
# If unset, a random UUID is generated per process.
# FOUNDRY_AGENT_SESSION_ID=
