########## azd → Terraform variable bindings ##########
##
## When `infra.provider: terraform` is set in azure.yaml, azd generates
## a `main.tfvars.json` at provision time from the azd environment. Every
## `azd env set FOO_BAR value` becomes a `TF_VAR_foo_bar=value` at plan
## time and shows up as `var.foo_bar` in Terraform.
##
## To force a mapping (e.g. AZURE_ENV_NAME -> environment_name), azd looks
## for a `main.tfvars.json` in the infra folder. This file is that mapping
## file — it references azd env vars via ${...} substitution, same syntax
## as infra/bicep/main.parameters.json for the Bicep path.
{
    "environment_name":                    "${AZURE_ENV_NAME}",
    "location":                            "${AZURE_LOCATION}",
    "principal_id":                        "${AZURE_PRINCIPAL_ID=}",
    "principal_type":                      "${AZURE_PRINCIPAL_TYPE=User}",

    "resource_group_name":                 "${AZURE_RESOURCE_GROUP=}",
    "vnet_name":                           "${AZURE_VNET_NAME=}",
    "ai_account_name":                     "${AZURE_AI_ACCOUNT_NAME=}",
    "ai_project_name":                     "${AZURE_AI_PROJECT_NAME=}",
    "cosmos_db_name":                      "${AZURE_COSMOS_DB_NAME=}",
    "ai_search_name":                      "${AZURE_AI_SEARCH_NAME=}",
    "storage_account_name":                "${AZURE_STORAGE_NAME=}",
    "acr_name":                            "${AZURE_ACR_NAME=}",

    "ai_services_name_prefix":             "${AZURE_AI_SERVICES_PREFIX=aifoundry}",
    "first_project_name":                  "${AZURE_AI_PROJECT_PREFIX=socproject}",

    "model_name":                          "${AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4}",
    "model_version":                       "${MODEL_VERSION=2026-03-05}",
    "model_format":                        "${MODEL_FORMAT=OpenAI}",
    "model_sku":                           "${MODEL_SKU=GlobalStandard}",
    "model_capacity":                      "${MODEL_CAPACITY=500}",

    "existing_resource_group_name":        "${EXISTING_RESOURCE_GROUP_NAME=}",
    "existing_vnet_id":                    "${EXISTING_VNET_RESOURCE_ID=}",
    "existing_agent_subnet_id":            "${EXISTING_AGENT_SUBNET_RESOURCE_ID=}",
    "existing_pe_subnet_id":               "${EXISTING_PE_SUBNET_RESOURCE_ID=}",
    "existing_mcp_subnet_id":              "${EXISTING_MCP_SUBNET_RESOURCE_ID=}",
    "existing_storage_account_id":         "${EXISTING_AZURE_STORAGE_ACCOUNT_RESOURCE_ID=}",
    "existing_cosmosdb_account_id":        "${EXISTING_AZURE_COSMOS_DB_ACCOUNT_RESOURCE_ID=}",
    "existing_ai_search_id":               "${EXISTING_AI_SEARCH_RESOURCE_ID=}",
    "existing_dns_zones_resource_group":   "${EXISTING_DNS_ZONES_RESOURCE_GROUP=}",
    "existing_dns_zones_subscription_id":  "${EXISTING_DNS_ZONES_SUBSCRIPTION_ID=}",

    "enable_container_registry":           "${ENABLE_CONTAINER_REGISTRY=true}",
    "developer_ip_cidr":                   "${DEVELOPER_IP_CIDR=}",

    "enable_mcp_http_server":              "${ENABLE_MCP_HTTP_SERVER=true}",
    "mcp_http_server_image_tag":           "${MCP_HTTP_SERVER_IMAGE_TAG=latest}",

    "capability_host_exists":              "${AZURE_CAPABILITY_HOST_EXISTS=false}"
}
